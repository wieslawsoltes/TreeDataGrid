<Application
    x:Class="TreeDataGridUnoActivityMonitor.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:TreeDataGridUnoActivityMonitor.Models"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///TreeDataGrid.Uno/Themes/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="TreeDataGridGridLinesBrush" Color="#1D91A0B2" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderBackgroundBrush" Color="#12171E26" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderBackgroundPointerOverBrush" Color="#1D24303D" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderBackgroundPressedBrush" Color="#26324052" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrush" Color="#24687889" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrushPointerOverBrush" Color="#3D8CA0B8" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrushPressedBrush" Color="#508CA0B8" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderForegroundBrush" Color="#FFF4E9D8" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderForegroundPointerOverBrush" Color="#FFFFF5E8" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderForegroundPressedBrush" Color="#FFFFF9F2" />
                    <SolidColorBrush x:Key="TreeDataGridRowBackgroundBrush" Color="#04000000" />
                    <SolidColorBrush x:Key="TreeDataGridAlternateRowBackgroundBrush" Color="#10101720" />
                    <SolidColorBrush x:Key="TreeDataGridSelectedRowBackgroundBrush" Color="#66367CC0" />
                    <SolidColorBrush x:Key="TreeDataGridSelectedCellBackgroundBrush" Color="#4D367CC0" />

                    <SolidColorBrush x:Key="TextControlForeground" Color="#FFF4E9D8" />
                    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#FFFFF6EB" />
                    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#88D7CFC4" />
                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#A3E3DBD1" />
                    <SolidColorBrush x:Key="TextControlBackground" Color="#1411171F" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#1A18202A" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#201A2430" />
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#336C7B8D" />
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#4A8AA1BA" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#669BC7F5" />
                    <SolidColorBrush x:Key="TextControlHeaderForeground" Color="#FFD7CFC4" />
                    <SolidColorBrush x:Key="TextControlHeaderForegroundFocused" Color="#FFF4E9D8" />
                    <SolidColorBrush x:Key="DiagnosticsOverlayBorderBrush" Color="#998CA0B8" />
                    <SolidColorBrush x:Key="DiagnosticsOverlayBackgroundBrush" Color="#CC101720" />
                    <SolidColorBrush x:Key="DiagnosticsAnchorFillBrush" Color="#FFF4E9D8" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="TreeDataGridGridLinesBrush" Color="#1D91A0B2" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderBackgroundBrush" Color="#12171E26" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderBackgroundPointerOverBrush" Color="#1D24303D" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderBackgroundPressedBrush" Color="#26324052" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrush" Color="#24687889" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrushPointerOverBrush" Color="#3D8CA0B8" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrushPressedBrush" Color="#508CA0B8" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderForegroundBrush" Color="#FFF4E9D8" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderForegroundPointerOverBrush" Color="#FFFFF5E8" />
                    <SolidColorBrush x:Key="TreeDataGridHeaderForegroundPressedBrush" Color="#FFFFF9F2" />
                    <SolidColorBrush x:Key="TreeDataGridRowBackgroundBrush" Color="#04000000" />
                    <SolidColorBrush x:Key="TreeDataGridAlternateRowBackgroundBrush" Color="#10101720" />
                    <SolidColorBrush x:Key="TreeDataGridSelectedRowBackgroundBrush" Color="#66367CC0" />
                    <SolidColorBrush x:Key="TreeDataGridSelectedCellBackgroundBrush" Color="#4D367CC0" />

                    <SolidColorBrush x:Key="TextControlForeground" Color="#FFF4E9D8" />
                    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#FFFFF6EB" />
                    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#88D7CFC4" />
                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#A3E3DBD1" />
                    <SolidColorBrush x:Key="TextControlBackground" Color="#1411171F" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#1A18202A" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#201A2430" />
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#336C7B8D" />
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#4A8AA1BA" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#669BC7F5" />
                    <SolidColorBrush x:Key="TextControlHeaderForeground" Color="#FFD7CFC4" />
                    <SolidColorBrush x:Key="TextControlHeaderForegroundFocused" Color="#FFF4E9D8" />
                    <SolidColorBrush x:Key="DiagnosticsOverlayBorderBrush" Color="#998CA0B8" />
                    <SolidColorBrush x:Key="DiagnosticsOverlayBackgroundBrush" Color="#CC101720" />
                    <SolidColorBrush x:Key="DiagnosticsAnchorFillBrush" Color="#FFF4E9D8" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <Color x:Key="AppBackgroundTopColor">#FF14181E</Color>
            <Color x:Key="AppBackgroundBottomColor">#FF0B0F14</Color>
            <Color x:Key="PanelSurfaceColor">#CC1C222B</Color>
            <Color x:Key="PanelChromeColor">#AA2B3440</Color>
            <Color x:Key="PanelBorderColor">#335A6574</Color>
            <Color x:Key="PanelMutedColor">#FF8D96A2</Color>
            <Color x:Key="PanelTextColor">#FFF4E9D8</Color>
            <Color x:Key="PanelTextSubtleColor">#FFB6AFA5</Color>
            <Color x:Key="CpuAccentColor">#FF5ED4FF</Color>
            <Color x:Key="MemoryAccentColor">#FFFFC857</Color>
            <Color x:Key="EnergyAccentColor">#FF8CE99A</Color>
            <Color x:Key="DiskAccentColor">#FFFF8F6B</Color>
            <Color x:Key="NetworkAccentColor">#FF7C9CFF</Color>

            <SolidColorBrush x:Key="PanelSurfaceBrush" Color="{StaticResource PanelSurfaceColor}" />
            <SolidColorBrush x:Key="PanelChromeBrush" Color="{StaticResource PanelChromeColor}" />
            <SolidColorBrush x:Key="PanelBorderBrush" Color="{StaticResource PanelBorderColor}" />
            <SolidColorBrush x:Key="PanelMutedBrush" Color="{StaticResource PanelMutedColor}" />
            <SolidColorBrush x:Key="PanelTextBrush" Color="{StaticResource PanelTextColor}" />
            <SolidColorBrush x:Key="PanelTextSubtleBrush" Color="{StaticResource PanelTextSubtleColor}" />
            <SolidColorBrush x:Key="CpuAccentBrush" Color="{StaticResource CpuAccentColor}" />
            <SolidColorBrush x:Key="MemoryAccentBrush" Color="{StaticResource MemoryAccentColor}" />
            <SolidColorBrush x:Key="EnergyAccentBrush" Color="{StaticResource EnergyAccentColor}" />
            <SolidColorBrush x:Key="DiskAccentBrush" Color="{StaticResource DiskAccentColor}" />
            <SolidColorBrush x:Key="NetworkAccentBrush" Color="{StaticResource NetworkAccentColor}" />

            <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="0.85,1">
                <GradientStop Color="{StaticResource AppBackgroundTopColor}" Offset="0" />
                <GradientStop Color="{StaticResource AppBackgroundBottomColor}" Offset="1" />
            </LinearGradientBrush>

            <Thickness x:Key="PanelPadding">18,16,18,16</Thickness>
            <CornerRadius x:Key="PanelCornerRadius">24</CornerRadius>

            <Style TargetType="TextBlock" x:Key="MetricCaptionTextStyle">
                <Setter Property="Foreground" Value="{StaticResource PanelMutedBrush}" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <Style TargetType="TextBlock" x:Key="SingleLineEllipsisTextStyle">
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style TargetType="TextBlock" x:Key="TwoLineEllipsisTextStyle">
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="MaxLines" Value="2" />
            </Style>

            <Style TargetType="TextBlock" x:Key="ThreeLineEllipsisTextStyle">
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="MaxLines" Value="3" />
            </Style>

            <Style TargetType="TextBlock" x:Key="FiveLineEllipsisTextStyle">
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="MaxLines" Value="5" />
            </Style>

            <Style TargetType="ToggleButton" x:Key="RailToggleButtonStyle">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="Padding" Value="14,12" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border
                                x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                                <ContentPresenter
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <DataTemplate x:Key="IdentityCell" x:DataType="models:MonitorRowBase">
                <Grid RowSpacing="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Foreground="{StaticResource PanelTextBrush}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Style="{StaticResource SingleLineEllipsisTextStyle}"
                            Text="{x:Bind Name}" />
                        <Border
                            Grid.Column="1"
                            x:Load="{x:Bind HasBadge, Mode=OneWay}"
                            Background="#22333D49"
                            BorderBrush="#44667A8F"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="8,2">
                            <TextBlock
                                Foreground="{StaticResource PanelTextBrush}"
                                FontSize="10"
                                Style="{StaticResource SingleLineEllipsisTextStyle}"
                                Text="{x:Bind BadgeText}" />
                        </Border>
                    </Grid>

                    <TextBlock
                        Grid.Row="1"
                        Foreground="{StaticResource PanelTextSubtleBrush}"
                        FontSize="11"
                        Style="{StaticResource SingleLineEllipsisTextStyle}"
                        Text="{x:Bind SecondaryText}" />
                </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
