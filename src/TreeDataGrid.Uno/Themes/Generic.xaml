<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Avalonia.Controls"
    xmlns:primitives="using:Avalonia.Controls.Primitives">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <SolidColorBrush x:Key="TreeDataGridGridLinesBrush" Color="#1A000000" />
            <SolidColorBrush x:Key="TreeDataGridHeaderBackgroundBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TreeDataGridHeaderBackgroundPointerOverBrush" Color="#1A000000" />
            <SolidColorBrush x:Key="TreeDataGridHeaderBackgroundPressedBrush" Color="#40000000" />
            <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrush" Color="#1A000000" />
            <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrushPointerOverBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrushPressedBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TreeDataGridHeaderForegroundBrush" Color="#FF000000" />
            <SolidColorBrush x:Key="TreeDataGridHeaderForegroundPointerOverBrush" Color="#FF000000" />
            <SolidColorBrush x:Key="TreeDataGridHeaderForegroundPressedBrush" Color="#FF000000" />
            <SolidColorBrush x:Key="TreeDataGridRowBackgroundBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TreeDataGridAlternateRowBackgroundBrush" Color="#06000000" />
            <SolidColorBrush x:Key="TreeDataGridSelectedRowBackgroundBrush" Color="#400078D4" />
            <SolidColorBrush x:Key="TreeDataGridSelectedCellBackgroundBrush" Color="#400078D4" />
            <SolidColorBrush x:Key="TreeDataGridDragIndicatorBrush" Color="#FF0078D4" />
            <SolidColorBrush x:Key="TreeDataGridDragIndicatorFillBrush" Color="#140078D4" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="TreeDataGridGridLinesBrush" Color="#1AFFFFFF" />
            <SolidColorBrush x:Key="TreeDataGridHeaderBackgroundBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TreeDataGridHeaderBackgroundPointerOverBrush" Color="#1AFFFFFF" />
            <SolidColorBrush x:Key="TreeDataGridHeaderBackgroundPressedBrush" Color="#40FFFFFF" />
            <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrush" Color="#1AFFFFFF" />
            <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrushPointerOverBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrushPressedBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TreeDataGridHeaderForegroundBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="TreeDataGridHeaderForegroundPointerOverBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="TreeDataGridHeaderForegroundPressedBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="TreeDataGridRowBackgroundBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TreeDataGridAlternateRowBackgroundBrush" Color="#10FFFFFF" />
            <SolidColorBrush x:Key="TreeDataGridSelectedRowBackgroundBrush" Color="#554C9DFF" />
            <SolidColorBrush x:Key="TreeDataGridSelectedCellBackgroundBrush" Color="#554C9DFF" />
            <SolidColorBrush x:Key="TreeDataGridDragIndicatorBrush" Color="#FF6CB8FF" />
            <SolidColorBrush x:Key="TreeDataGridDragIndicatorFillBrush" Color="#226CB8FF" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <Thickness x:Key="TreeDataGridHeaderPadding">8,6,8,6</Thickness>
    <Thickness x:Key="TreeDataGridCellPadding">8,4,8,4</Thickness>
    <Thickness x:Key="TreeDataGridHierarchyCellPadding">4,4,8,4</Thickness>
    <x:String x:Key="TreeDataGridCollapsedGlyph">▸</x:String>
    <x:String x:Key="TreeDataGridExpandedGlyph">▾</x:String>

    <Style x:Key="TreeDataGridExpanderToggleStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Content="{TemplateBinding Content}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="local:TreeDataGrid">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{ThemeResource TreeDataGridGridLinesBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:TreeDataGrid">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <ScrollViewer x:Name="PART_HeaderScrollViewer"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled"
                                          HorizontalScrollMode="Enabled"
                                          VerticalScrollMode="Disabled"
                                          ZoomMode="Disabled">
                                <primitives:TreeDataGridColumnHeadersPresenter x:Name="PART_ColumnHeadersPresenter" />
                            </ScrollViewer>
                            <ScrollViewer x:Name="PART_ScrollViewer"
                                          Grid.Row="1"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollMode="Enabled"
                                          VerticalScrollMode="Enabled"
                                          IsScrollInertiaEnabled="True"
                                          IsHorizontalRailEnabled="True"
                                           IsVerticalRailEnabled="True"
                                           ZoomMode="Disabled">
                                <primitives:TreeDataGridRowsPresenter x:Name="PART_RowsPresenter" />
                            </ScrollViewer>
                            <Canvas x:Name="PART_DragIndicatorHost"
                                    Grid.RowSpan="2"
                                    IsHitTestVisible="False">
                                <Border x:Name="PART_DragIndicatorLine"
                                        Width="0"
                                        Height="2"
                                        Background="{ThemeResource TreeDataGridDragIndicatorBrush}"
                                        CornerRadius="1"
                                        Visibility="Collapsed" />
                                <Border x:Name="PART_DragIndicatorBox"
                                        Width="0"
                                        Height="0"
                                        Background="{ThemeResource TreeDataGridDragIndicatorFillBrush}"
                                        BorderBrush="{ThemeResource TreeDataGridDragIndicatorBrush}"
                                        BorderThickness="2"
                                        Visibility="Collapsed" />
                            </Canvas>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="primitives:TreeDataGridColumnHeader">
        <Setter Property="MinHeight" Value="25" />
        <Setter Property="Padding" Value="{ThemeResource TreeDataGridHeaderPadding}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{ThemeResource TreeDataGridHeaderForegroundBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="primitives:TreeDataGridColumnHeader">
                    <Border x:Name="PART_RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{ThemeResource TreeDataGridGridLinesBrush}"
                            BorderThickness="0,0,1,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="5" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}" />
                            <Grid Grid.Column="1"
                                  Width="12"
                                  Height="12"
                                  Margin="0,0,6,0"
                                  VerticalAlignment="Center">
                                <Path x:Name="PART_SortAscendingGlyph"
                                      Data="M1965 947l-941 -941l-941 941l90 90l787 -787v1798h128v-1798l787 787z"
                                      Fill="{TemplateBinding Foreground}"
                                      Stretch="Uniform"
                                      Visibility="Collapsed" />
                                <Path x:Name="PART_SortDescendingGlyph"
                                      Data="M1875 1011l-787 787v-1798h-128v1798l-787 -787l-90 90l941 941l941 -941z"
                                      Fill="{TemplateBinding Foreground}"
                                      Stretch="Uniform"
                                      Visibility="Collapsed" />
                            </Grid>
                            <Thumb x:Name="PART_Resizer"
                                   Grid.Column="2"
                                   Background="Transparent"
                                   HorizontalAlignment="Stretch" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="primitives:TreeDataGridRow">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="primitives:TreeDataGridRow">
                    <Border Background="{TemplateBinding Background}">
                        <primitives:TreeDataGridCellsPresenter x:Name="PART_CellsPresenter" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="primitives:TreeDataGridTextCell">
        <Setter Property="MinHeight" Value="25" />
        <Setter Property="BorderBrush" Value="{ThemeResource TreeDataGridGridLinesBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="{ThemeResource TreeDataGridCellPadding}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="primitives:TreeDataGridTextCell">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <TextBlock x:Name="PART_DisplayText" VerticalAlignment="Center" />
                            <TextBox x:Name="PART_EditText"
                                     Visibility="Collapsed"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="primitives:TreeDataGridCheckBoxCell">
        <Setter Property="MinHeight" Value="25" />
        <Setter Property="BorderBrush" Value="{ThemeResource TreeDataGridGridLinesBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="{ThemeResource TreeDataGridCellPadding}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="primitives:TreeDataGridCheckBoxCell">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <CheckBox x:Name="PART_CheckBox"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="primitives:TreeDataGridExpanderCell">
        <Setter Property="MinHeight" Value="25" />
        <Setter Property="BorderBrush" Value="{ThemeResource TreeDataGridGridLinesBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="{ThemeResource TreeDataGridHierarchyCellPadding}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="primitives:TreeDataGridExpanderCell">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="PART_IndentSpacer"
                                    Grid.Column="0"
                                    Width="0" />
                             <ToggleButton x:Name="PART_ExpanderToggle"
                                           Grid.Column="1"
                                           Style="{StaticResource TreeDataGridExpanderToggleStyle}"
                                           Width="12"
                                           Height="12"
                                           Padding="0"
                                           HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsTabStop="False">
                                <TextBlock x:Name="PART_ExpanderGlyph"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </ToggleButton>
                            <Border x:Name="PART_ContentHost"
                                    Grid.Column="2" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="primitives:TreeDataGridTemplateCell">
        <Setter Property="MinHeight" Value="25" />
        <Setter Property="BorderBrush" Value="{ThemeResource TreeDataGridGridLinesBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="{ThemeResource TreeDataGridCellPadding}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="primitives:TreeDataGridTemplateCell">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <ContentPresenter x:Name="PART_DisplayContentPresenter"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                            <ContentPresenter x:Name="PART_EditingContentPresenter"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              Visibility="Collapsed" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
